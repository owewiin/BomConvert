<Window x:Class="SchBom_Convert.ComponentMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="🧩 元件映射管理"
        Height="600" Width="900"
        MinHeight="400" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <DockPanel>
        <!-- 頂部說明 -->
        <StackPanel DockPanel.Dock="Top" Margin="16,12,16,8">
            <TextBlock Text="🧩 元件映射管理"
                       FontSize="20" FontWeight="Bold" Foreground="#2E3B4E"/>
            <TextBlock Text="清單順序 = 比對優先序，越上面越優先（例：合金電阻 要排在 電阻 之前）。拖曳列首 ≡ 可調整順序。關鍵字以逗號分隔。"
                       FontSize="12" Foreground="#888" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 底部按鈕列 -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <WrapPanel Orientation="Horizontal" Margin="12,8">
                <Button Content="➕ 新增列" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4,8,4" Click="AddRow_Click"/>
                <Button Content="🗑 刪除列" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4,8,4" Click="DeleteRow_Click"/>
                <Button Content="⬆ 上移" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4,8,4" Click="MoveUp_Click"/>
                <Button Content="⬇ 下移" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4,8,4" Click="MoveDown_Click"/>
                <Button Content="♻ 還原預設" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#CC4165" Margin="0,4,8,4" Click="ResetDefaults_Click"/>
                <Button Content="💾 儲存" Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#4CAF50" Foreground="White" Margin="20,4,8,4" Click="Save_Click"/>
                <Button Content="🔙 關閉" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4,0,4" Click="Close_Click"/>
            </WrapPanel>
        </Border>

        <!-- 中央規則表 -->
        <DataGrid x:Name="MappingGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="MappingGrid_PreviewMouseLeftButtonDown"
                  MouseMove="MappingGrid_MouseMove"
                  DragOver="MappingGrid_DragOver"
                  Drop="MappingGrid_Drop"
                  Margin="16,0,16,8">
            <DataGrid.Columns>
                <DataGridTemplateColumn x:Name="HandleColumn" Header="" Width="36"
                                        CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="≡" FontSize="14" Foreground="#999"
                                       Cursor="SizeNS"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       ToolTip="拖曳此處可調整順序"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="分類名稱" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="類別" Binding="{Binding Category}" Width="80"/>
                <DataGridTextColumn Header="關鍵字（逗號分隔）" Binding="{Binding KeywordsText}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
